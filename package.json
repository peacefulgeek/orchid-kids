{
  "name": "orchid-kids",
  "version": "1.0.0",
  "description": "Orchid Kids — The research-backed, shame-free resource for parents of highly sensitive children",
  "type": "module",
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "NODE_ENV=development concurrently \"node scripts/start-dev.mjs\" \"vite\"",
    "build": "pnpm build:client && pnpm build:server && pnpm check:no-images-in-repo",
    "build:client": "vite build --outDir dist/client --ssrManifest",
    "build:server": "node scripts/build-server.mjs",
    "check:no-images-in-repo": "node scripts/check-no-images.mjs",
    "start": "NODE_ENV=production node scripts/start-with-cron.mjs",
    "preview": "NODE_ENV=production node dist/index.js",
    "seed": "node scripts/bulk-seed.mjs",
    "visual-qa": "node scripts/visual-qa.mjs",
    "migrate-images": "node scripts/migrate-images-to-bunny.mjs"
  },
  "dependencies": {
    "compression": "^1.7.4",
    "express": "^4.21.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.16",
    "openai": "^4.71.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^8.2.2",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  }
}
