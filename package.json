{
  "name": "raising-orchids",
  "version": "1.0.0",
  "description": "Raising Orchids — The research-backed, shame-free resource for parents of highly sensitive children",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"pnpm dev:server\" \"pnpm dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "pnpm build:client && pnpm build:server",
    "build:client": "vite build",
    "build:server": "node scripts/build-server.mjs",
    "start": "NODE_ENV=production node scripts/start-with-cron.mjs",
    "preview": "NODE_ENV=production node dist/index.js",
    "seed": "node scripts/bulk-seed.mjs",
    "visual-qa": "node scripts/visual-qa.mjs",
    "migrate-images": "node scripts/migrate-images-to-bunny.mjs"
  },
  "dependencies": {
    "compression": "^1.7.4",
    "express": "^4.19.2",
    "node-cron": "^3.0.3",
    "openai": "^4.52.7",
    "pg": "^8.12.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.24.1",
    "serve-static": "^1.15.0"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.10",
    "@types/pg": "^8.11.6",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "esbuild": "^0.21.5",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vite": "^5.3.3"
  },
  "engines": {
    "node": ">=20"
  }
}
