# Copy to .env and fill in values — NEVER commit .env to git

NODE_ENV=development
PORT=3000
SITE_ORIGIN=https://orchidkids.com

# Writing engine (OpenAI GPT-4.1-mini)
OPENAI_API_KEY=sk-your-openai-key-here

# Database (optional — uses JSON file store if not set)
DATABASE_URL=postgresql://user:password@localhost:5432/orchid_kids

# Bunny CDN (orchid-kids2 zone)
BUNNY_API_KEY=your-bunny-api-key-here
BUNNY_STORAGE_ZONE=orchid-kids2
BUNNY_PULL_ZONE=https://orchid-kids2.b-cdn.net
BUNNY_HOSTNAME=ny.storage.bunnycdn.com

# Cron + auto-publishing
AUTO_GEN_ENABLED=true
ARTICLES_PER_DAY=3

# Affiliate
AMAZON_TAG=spankyspinola-20
