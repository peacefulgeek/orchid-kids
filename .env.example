# Copy to .env and fill in values — NEVER commit .env to git

NODE_ENV=development
PORT=3000

# Writing engine (DeepSeek via OpenAI client)
OPENAI_API_KEY=sk-your-deepseek-key-here
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-v4-pro

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/raising_orchids

# Cron + auto-publishing
AUTO_GEN_ENABLED=true

# GitHub (for image migration scripts)
GH_PAT=ghp_your_token_here

# Affiliate
AMAZON_TAG=spankyspinola-20
