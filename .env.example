# OrchidKids.com — Environment Variables
# Copy to .env for local development — NEVER commit .env to git
# For Render: set these in the Render dashboard under Environment

NODE_ENV=development
PORT=3000
SITE_ORIGIN=https://orchidkids.com

# Writing engine (OpenAI GPT-4.1-mini — for quarterly refresh cron)
OPENAI_API_KEY=sk-your-openai-key-here

# Bunny CDN (orchid-kids2 zone — New York)
BUNNY_API_KEY=your-bunny-write-key-here
BUNNY_STORAGE_ZONE=orchid-kids2
BUNNY_PULL_ZONE=https://orchid-kids2.b-cdn.net
BUNNY_HOSTNAME=ny.storage.bunnycdn.com

# Cron settings
AUTO_GEN_ENABLED=true
ARTICLES_PER_DAY=3

# Affiliate
AMAZON_TAG=spankyspinola-20

# Database (optional — app uses JSON file store if not set)
# DATABASE_URL=postgresql://user:password@host:5432/orchid_kids
